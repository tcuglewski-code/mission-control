DATABASE_URL="file:./dev.db"
# For PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@host:5432/mission_control"
NEXT_PUBLIC_APP_NAME="Mission Control"

# GitHub Webhook Signatur-Secret (HMAC-SHA256)
# Muss mit dem Secret in den GitHub Repo-Webhooks übereinstimmen
GITHUB_WEBHOOK_SECRET=KochAufforstungWebhook2026

# E-Mail Webhook Secret — Header: x-email-webhook-secret
# Schützt den POST /api/webhooks/email Endpunkt vor unbefugtem Zugriff
EMAIL_WEBHOOK_SECRET=dein_geheimes_email_webhook_secret

# ────────────────────────────────────────────────────────────────────────────
# Support-Webhook (Ticket-System)
# ────────────────────────────────────────────────────────────────────────────
# POST /api/webhooks/support nimmt Support-Anfragen entgegen und erstellt Tickets.
# Zwei Auth-Optionen: x-api-key (MC_API_KEY) oder x-support-secret
#
# Generieren mit: openssl rand -base64 32
SUPPORT_WEBHOOK_SECRET=your_support_webhook_secret_here

# MC API Key für externe Services (Lead-Webhook, Support-Webhook, etc.)
MC_API_KEY=mc_live_your_api_key_here

# ────────────────────────────────────────────────────────────────────────────
# SMTP E-Mail-Versand (optional)
# ────────────────────────────────────────────────────────────────────────────
# Ohne diese Variablen läuft das System im Preview-Modus:
# E-Mails werden generiert aber nicht gesendet (graceful degradation).
#
# Alle 5 Variablen müssen gesetzt sein für echten E-Mail-Versand:

# SMTP Server Hostname (z.B. smtp.mailgun.org, smtp.sendgrid.net)
SMTP_HOST=smtp.example.com

# SMTP Port (587 für TLS/STARTTLS, 465 für SSL)
SMTP_PORT=587

# SMTP Anmeldedaten
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Absender-Adresse (ohne diese wird noreply@kochaufforstung.de verwendet)
SMTP_FROM=noreply@kochaufforstung.de

# ────────────────────────────────────────────────────────────────────────────
# Vercel Cron Jobs — Sicherheit
# ────────────────────────────────────────────────────────────────────────────
# CRON_SECRET wird von Vercel automatisch als Authorization: Bearer <secret>
# Header an Cron-Routen gesendet. PFLICHT in Production!
#
# Generieren mit: openssl rand -base64 32
CRON_SECRET=your_cron_secret_here

# Nur für Development: Cron-Routen ohne Secret erlauben
# ACHTUNG: Niemals in Production auf "true" setzen!
# ALLOW_DEV_CRON=true

# ────────────────────────────────────────────────────────────────────────────
# Telegram Alerts (Uptime Monitoring)
# ────────────────────────────────────────────────────────────────────────────
# Für Uptime-Alerts bei Ausfällen. Erstelle einen Bot via @BotFather.
# Chat-ID findest du via @getidsbot (Gruppe = negative Zahl mit -100 Präfix).
#
# Ohne diese Variablen funktioniert das Monitoring, aber ohne Alerts.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890
