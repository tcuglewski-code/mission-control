DATABASE_URL="file:./dev.db"
# For PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@host:5432/mission_control"
NEXT_PUBLIC_APP_NAME="Mission Control"

# GitHub Webhook Signatur-Secret (HMAC-SHA256)
# Muss mit dem Secret in den GitHub Repo-Webhooks übereinstimmen
GITHUB_WEBHOOK_SECRET=KochAufforstungWebhook2026

# E-Mail Webhook Secret — Header: x-email-webhook-secret
# Schützt den POST /api/webhooks/email Endpunkt vor unbefugtem Zugriff
EMAIL_WEBHOOK_SECRET=dein_geheimes_email_webhook_secret

# ────────────────────────────────────────────────────────────────────────────
# SMTP E-Mail-Versand (optional)
# ────────────────────────────────────────────────────────────────────────────
# Ohne diese Variablen läuft das System im Preview-Modus:
# E-Mails werden generiert aber nicht gesendet (graceful degradation).
#
# Alle 5 Variablen müssen gesetzt sein für echten E-Mail-Versand:

# SMTP Server Hostname (z.B. smtp.mailgun.org, smtp.sendgrid.net)
SMTP_HOST=smtp.example.com

# SMTP Port (587 für TLS/STARTTLS, 465 für SSL)
SMTP_PORT=587

# SMTP Anmeldedaten
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Absender-Adresse (ohne diese wird noreply@kochaufforstung.de verwendet)
SMTP_FROM=noreply@kochaufforstung.de
