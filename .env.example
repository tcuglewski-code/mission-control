DATABASE_URL="file:./dev.db"
# For PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@host:5432/mission_control"
NEXT_PUBLIC_APP_NAME="Mission Control"

# GitHub Webhook Signatur-Secret (HMAC-SHA256)
# Muss mit dem Secret in den GitHub Repo-Webhooks übereinstimmen
GITHUB_WEBHOOK_SECRET=KochAufforstungWebhook2026

# E-Mail Webhook Secret — Header: x-email-webhook-secret
# Schützt den POST /api/webhooks/email Endpunkt vor unbefugtem Zugriff
EMAIL_WEBHOOK_SECRET=dein_geheimes_email_webhook_secret
