generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RecurringInterval {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  role           String          @default("human")
  avatar         String?
  description    String?
  tools          String? // JSON array of tool names
  skills         String? // JSON array of skill names
  weeklyCapacity Int             @default(40) // Wochenkapazität in Stunden
  hourlyRate     Float           @default(0) // Stundensatz in € für Personalkosten-Kalkulation
  createdAt      DateTime        @default(now())
  tasks          Task[]
  projects       ProjectMember[]
  logs           ActivityLog[]
  tickets        Ticket[]
}

model Project {
  id              String            @id @default(cuid())
  name            String
  description     String?
  longDescription String? // Living document — grows with the project
  status          String            @default("active")
  progress        Int               @default(0)
  priority        String            @default("medium")
  color           String            @default("#3b82f6")
  // Meta / Links
  githubRepo      String? // e.g. "tcuglewski-code/ka-app"
  liveUrl         String? // Production URL
  vercelUrl       String? // Vercel deployment URL
  expoProjectId   String? // Expo / EAS project ID
  stack           String? // Tech stack description
  budget          Float? // Geplantes Budget in €
  budgetUsed      Float?            @default(0) // Verbrauchtes Budget
  hourBudget      Float? // Geplante Stunden (Stundenbudget)
  clientId        String?
  client          Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  archived        Boolean           @default(false)
  archivedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tasks           Task[]
  sprints         Sprint[]
  milestones      Milestone[]
  members         ProjectMember[]
  docs            Document[]
  fileDocs        FileDoc[]
  logs            ActivityLog[]
  databases       Database[]
  tickets         Ticket[]
  webhooks        Webhook[]
  invoices        Invoice[]
  favorites       ProjectFavorite[]
  costs           ProjectCost[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("viewer") // owner | editor | viewer
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Task {
  id                String             @id @default(cuid())
  title             String
  description       String?
  status            String             @default("todo")
  priority          String             @default("medium")
  labels            String?
  dueDate           DateTime?
  startDate         DateTime?
  agentPrompt       String?
  timeSpentSeconds  Int                @default(0)
  storyPoints       Int?
  sourceEmailId     String?
  // ─── Wiederkehrende Tasks ──────────────────────────────────────────────────
  shortId           Int? // Kurzreferenz für GitHub #NNN
  recurring         Boolean            @default(false)
  recurringInterval RecurringInterval?
  recurringDay      Int? // Wochentag 1-7 (Mo=1) oder Tag des Monats 1-31
  recurringEndDate  DateTime? // Wann endet die Wiederholung
  parentTaskId      String? // ID der Ursprungs-Task (bei erzeugten Kopien)
  startAfterTaskId  String? // Startet erst nach: ID der Vorgänger-Task
  // ─── ICE Scoring (AF058) ───────────────────────────────────────────────────
  iceImpact         Int? // 1-10: Wie viel Wert bringt das Feature?
  iceConfidence     Int? // 1-10: Wie sicher sind wir bei der Einschätzung?
  iceEase           Int? // 1-10: Wie einfach ist die Umsetzung?
  iceScore          Float? // Berechnet: (Impact × Confidence × Ease) / 10
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  projectId         String?
  assigneeId        String?
  sprintId          String?
  milestoneId       String?
  project           Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee          User?              @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  sprint            Sprint?            @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  milestone         Milestone?         @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  sourceEmail       InboxEmail?        @relation(fields: [sourceEmailId], references: [id], onDelete: SetNull)
  parentTask        Task?              @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks          Task[]             @relation("TaskSubtasks")
  comments          TaskComment[]
  events            Event[]
  timeEntries       TimeEntry[]
  taskLabels        TaskLabel[]
}

// ─── Board-Spalten ────────────────────────────────────────────────────────────
model BoardColumn {
  id        String   @id @default(cuid())
  projectId String? // null = globale Standard-Spalte
  name      String
  statusKey String // interner Schlüssel z.B. "todo", "in_progress", "review", "done"
  order     Int      @default(0)
  wipLimit  Int? // null = kein Limit
  color     String   @default("#6b7280")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── E-Mail Posteingang ───────────────────────────────────────────────────────
model InboxEmail {
  id          String   @id @default(cuid())
  from        String
  subject     String
  body        String?
  preview     String? // Vorschautext (max. 200 Zeichen)
  receivedAt  DateTime @default(now())
  read        Boolean  @default(false)
  taskCreated Boolean  @default(false)
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Label {
  id         String      @id @default(cuid())
  name       String      @unique
  color      String      @default("#6b7280")
  createdAt  DateTime    @default(now())
  taskLabels TaskLabel[]
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

model TimeEntry {
  id          String    @id @default(cuid())
  taskId      String
  userId      String?
  description String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int? // Minuten
  billable    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Sprint {
  id              String    @id @default(cuid())
  name            String
  description     String?
  status          String    @default("planning")
  startDate       DateTime?
  endDate         DateTime?
  goal            String?
  projectId       String?
  storyPoints     Int?
  completedPoints Int?
  memberIds       String? // JSON array of user IDs assigned to this sprint
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tasks           Task[]
}

model TaskComment {
  id          String            @id @default(cuid())
  content     String
  taskId      String
  authorId    String?
  authorName  String            @default("Amadeus")
  authorEmail String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  task        Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reactions   CommentReaction[]
}

// ─── Kommentar-Reaktionen ─────────────────────────────────────────────────────
model CommentReaction {
  id        String      @id @default(cuid())
  commentId String
  userId    String // AuthUser ID
  emoji     String // z.B. "👍", "❤️", "😄", "🎉", "👀", "🚀"
  createdAt DateTime    @default(now())
  comment   TaskComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
}

model Document {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String   @default("doc")
  tags      String?
  projectId String?
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model MemoryEntry {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("general")
  type      String   @default("journal") // "journal" | "longterm"
  tags      String?
  source    String?
  projectId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tool {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("api")
  status      String   @default("active")
  config      String?
  projectIds  String?
  createdAt   DateTime @default(now())
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String    @default("task")
  color       String    @default("#3b82f6")
  startTime   DateTime
  endTime     DateTime?
  recurring   String?
  taskId      String?
  createdAt   DateTime  @default(now())
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  entityName String
  userId     String?
  userEmail  String?
  projectId  String?
  metadata   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model CronJob {
  id            String    @id @default(cuid())
  name          String
  description   String?
  schedule      String
  scheduleHuman String?
  type          String    @default("system")
  status        String    @default("active")
  lastRun       DateTime?
  nextRun       DateTime?
  payload       String?
  projectId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Database {
  id          String    @id @default(cuid())
  name        String
  type        String // "postgresql", "mysql", "mongodb", "watermelondb", "neon"
  host        String?
  port        Int?
  status      String    @default("unknown") // "connected", "disconnected", "unknown"
  sizeBytes   BigInt?
  lastBackup  DateTime?
  lastChecked DateTime?
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Ticket {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("open") // "open", "in_progress", "resolved", "closed"
  priority    String   @default("medium") // "low", "medium", "high", "critical"
  category    String? // "bug", "feature", "support", "question"
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  assigneeId  String?
  assignee    User?    @relation(fields: [assigneeId], references: [id])
  taskId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Webhook {
  id            String    @id @default(cuid())
  name          String
  url           String
  secret        String?
  events        String[]
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  active        Boolean   @default(true)
  lastTriggered DateTime?
  lastStatus    Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model WebhookLog {
  id        String   @id @default(cuid())
  webhookId String
  event     String
  payload   String
  status    Int
  response  String?
  duration  Int
  createdAt DateTime @default(now())
}

model AuthUser {
  id                   String         @id @default(cuid())
  username             String         @unique
  email                String?
  passwordHash         String
  role                 String         @default("user") // "admin" | "user"
  mcRole               String         @default("entwickler") // "admin" | "projektmanager" | "entwickler" | "beobachter"
  active               Boolean        @default(true)
  lastLoginAt          DateTime?
  projectAccess        String[] // Array von Project-IDs (leer = kein Zugang für user)
  permissions          String[] // Granulare Rechte z.B. ["projects.view", "tasks.view"]
  notifEmailDigest     Boolean        @default(true)
  notifPush            Boolean        @default(false)
  notifPrefs           String? // JSON: { eventPrefs: {...}, quietHoursStart, quietHoursEnd, digestFrequency, digestTime }
  quietHoursStart      Int            @default(22) // Ruhezeit ab (Stunde 0-23)
  quietHoursEnd        Int            @default(8) // Ruhezeit bis (Stunde 0-23)
  digestFrequency      String         @default("daily") // "daily" | "weekly" | "never"
  digestTime           String         @default("08:00") // HH:MM
  onboardingComplete   Boolean        @default(false)
  tourComplete         Boolean        @default(false)
  theme                String         @default("system") // "light" | "dark" | "wald" | "system"
  compact              Boolean        @default(false) // Kompaktmodus
  hourlyRate           Float          @default(0) // Stundensatz in € für Personalkosten
  // Sprint Q016: 2FA TOTP
  twoFactorSecret      String? // Base32-encoded TOTP secret
  twoFactorEnabled     Boolean        @default(false)
  twoFactorBackupCodes String[]       @default([]) // Hashed backup codes
  twoFactorVerifiedAt  DateTime? // When 2FA was first verified
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  notifications        Notification[]
}

// ─── Fehler-Protokoll ─────────────────────────────────────────────────────────
model ErrorLog {
  id         String   @id @default(cuid())
  path       String
  method     String   @default("GET")
  statusCode Int      @default(500)
  message    String
  stack      String?
  userId     String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // "task_update" | "deadline" | "cron_result" | "mention"
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invitation {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  email       String?
  role        String    @default("entwickler") // admin | projektmanager | entwickler | beobachter
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String
}

// UserInvite — erweitertes Einladungssystem mit 48h-Token
model UserInvite {
  id          String   @id @default(cuid())
  email       String
  token       String   @unique @default(cuid())
  role        String   @default("entwickler") // admin | projektmanager | entwickler | beobachter
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdById String?
  createdAt   DateTime @default(now())
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  keyPrefix  String
  userId     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
}

// ─── Agent Registry (erweitert) ───────────────────────────────────────────────
model AgentRegistry {
  id               String    @id @default(cuid())
  name             String    @unique
  beschreibung     String?
  capabilities     String[] // Liste der Fähigkeiten z.B. ["code", "search", "email"]
  status           String    @default("unknown") // "online" | "offline" | "unknown"
  letzteAktivitaet DateTime?
  version          String?
  endpoint         String? // API-Endpoint des Agenten (optional)
  metadata         String? // JSON für zusätzliche Felder
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─── Daily Digest ─────────────────────────────────────────────────────────────
model DailyDigest {
  id         String   @id @default(cuid())
  datum      DateTime @unique
  inhalt     String // Markdown-Zusammenfassung
  tasksDone  Int      @default(0)
  tasksOffen Int      @default(0)
  tasksNeu   Int      @default(0)
  createdAt  DateTime @default(now())
}

// ─── Task Dependencies ────────────────────────────────────────────────────────
model TaskDependency {
  id          String  @id @default(cuid())
  taskId      String
  dependsOnId String
  isBlocker   Boolean @default(false) // true = blockierende Abhängigkeit (Task kann nicht auf "done" bis Blocker erledigt)

  @@unique([taskId, dependsOnId])
}

// ─── Projekt-Vorlagen ─────────────────────────────────────────────────────────
model ProjectTemplate {
  id            String   @id @default(cuid())
  name          String
  description   String?
  category      String? // "aufforstung", "pflege", "saatgut", "foerderung", etc.
  tasks         Json // Array von Task-Definitionen
  milestones    Json? // Array von Meilenstein-Definitionen (Sprint GG)
  isSystem      Boolean  @default(false) // System-Vorlagen (forstspezifisch)
  createdBy     String? // User ID des Erstellers
  createdByName String? // Anzeigename des Erstellers
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Webhook Einstellungen (ausgehend) ────────────────────────────────────────
model WebhookEinstellung {
  id        String   @id @default(cuid())
  name      String
  url       String
  events    String[] // "task.created" | "task.updated" | "task.completed" | "task.deleted"
  aktiv     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Ankündigungen ────────────────────────────────────────────────────────────
model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  priority  String   @default("normal") // "normal", "wichtig", "dringend"
  authorId  String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Datei-Dokumente (Link-Upload) ────────────────────────────────────────────
model FileDoc {
  id            String   @id @default(cuid())
  name          String
  description   String?
  url           String // Externe URL oder interner Download-Link
  fileType      String   @default("link") // "pdf" | "word" | "excel" | "image" | "link" | "other"
  size          Int? // Dateigröße in Bytes (null bei Links)
  uploader      String   @default("System")
  uploaderEmail String?
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Rechnungen / Invoices ────────────────────────────────────────────────────
model Invoice {
  id            String        @id @default(cuid())
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number        String // Rechnungsnummer z.B. RE-2024-001
  description   String?
  amount        Float // Brutto-Betrag in €
  status        String        @default("OPEN") // OPEN | SENT | PARTIAL | PAID | OVERDUE | CANCELLED | DRAFT
  invoiceDate   DateTime      @default(now())
  dueDate       DateTime
  paidAt        DateTime?
  // Zahlungseingang (Legacy + neu via Payment-Tabelle)
  paymentMethod String? // "Überweisung" | "Bar" | "EC" | "PayPal"
  paymentAmount Float? // Gesamtbetrag aller Zahlungen (wird automatisch aktualisiert)
  paymentDate   DateTime? // Datum der letzten Zahlung
  // Mahnwesen
  dunningLevel  Int           @default(0) // 0 = keine Mahnung, 1/2/3
  dunningDate   DateTime? // Datum der letzten Mahnung
  dunningFee    Float         @default(0) // Mahngebühr gesamt in €
  // Vorlage-Referenz
  templateId    String? // Welche Vorlage wurde verwendet?
  // Kundenadresse
  clientName    String?
  clientAddress String? // Mehrzeilig
  // Zahlungsbedingungen + Bank
  paymentTerms   String?       @default("Zahlbar innerhalb von 14 Tagen ohne Abzug.")
  bankDetails    String?       @default("Koch Aufforstung GmbH · IBAN: DE00 0000 0000 0000 0000 00 · BIC: XXXXXXXX")
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  items          InvoiceItem[]
  reminders      InvoiceReminder[]
  payments       Payment[]
  Client         Client?       @relation(fields: [clientId], references: [id])
  clientId       String?
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float    @default(1)
  unitPrice   Float
  vatRate     Float    @default(19) // 7 oder 19 (Prozent)
  position    Int      @default(0) // Reihenfolge
  createdAt   DateTime @default(now())
}

// ─── Zahlungs-Tracking ────────────────────────────────────────────────────────
model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Float
  date      DateTime @default(now())
  method    String   @default("Überweisung") // "Überweisung" | "Bar" | "EC-Karte" | "PayPal" | "Lastschrift"
  note      String?
  createdAt DateTime @default(now())
}

// ─── Mahnungs-Tracking (automatisch via Cron) ─────────────────────────────────
model InvoiceReminder {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  level       Int      // 1 = 1. Mahnung, 2 = 2. Mahnung, 3 = letzte Mahnung
  fee         Float    @default(0) // Mahngebühr für diese Stufe
  sentAt      DateTime @default(now())
  sentVia     String   @default("system") // "system" | "email" | "post"
  note        String?
  createdAt   DateTime @default(now())
  @@index([invoiceId])
}

// ─── Betriebsausgaben (AF069: Cash Flow Dashboard) ───────────────────────────
model Expense {
  id          String   @id @default(cuid())
  title       String
  description String?
  amount      Float    // Betrag in €
  category    String   @default("Sonstiges") // "Hosting" | "SaaS" | "Personal" | "Marketing" | "Tools" | "Sonstiges"
  vendor      String?  // Anbieter z.B. "Vercel", "Neon", "Anthropic", "Expo"
  date        DateTime @default(now())
  recurring   Boolean  @default(false) // Monatlich wiederkehrende Kosten?
  projectId   String?  // Optional: Zuordnung zu Projekt
  notes       String?
  receipt     String?  // URL zum Beleg (optional)
  createdBy   String?  // AuthUser ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([date])
  @@index([category])
}

// ─── Rechnungs-Vorlagen ───────────────────────────────────────────────────────
model InvoiceTemplate {
  id          String    @id @default(cuid())
  name        String
  description String?
  amount      Float // Betrag in €
  status      String    @default("OPEN") // OPEN | PAID | OVERDUE | CANCELLED
  dueDate     DateTime
  // Kunden-Verknüpfung
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  paidAt      DateTime?
  positions   String? // JSON: Array von { description, quantity, unitPrice, vatRate }
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Persönliche Tagesnotizen ─────────────────────────────────────────────────
model UserDayNote {
  id        String   @id @default(cuid())
  userId    String
  date      String // ISO-Datum "2024-03-28"
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

// ─── Heutiger Fokus (max. 3 Tasks) ────────────────────────────────────────────
model UserTaskFocus {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  date      String // ISO-Datum "2024-03-28"
  createdAt DateTime @default(now())

  @@unique([userId, taskId, date])
}

// ─── Meilensteine ─────────────────────────────────────────────────────────────
model Milestone {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("planned") // "planned", "active", "completed", "cancelled"
  progress    Int       @default(0) // 0-100, kann automatisch aus Tasks berechnet werden
  color       String    @default("#8b5cf6")
  dueDate     DateTime?
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Projekt-Sharing ──────────────────────────────────────────────────────────
model ProjectShare {
  id               String         @id @default(cuid())
  projectId        String
  token            String         @unique @default(cuid())
  label            String? // Optionale Bezeichnung z.B. "Kunde Müller"
  expiresAt        DateTime?
  passwordHash     String? // SHA256-Hash für optionalen Passwortschutz
  showTimeTracking Boolean        @default(false)
  showCosts        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  guestComments    GuestComment[]
}

// ─── Gast-Kommentare (Kunden-Portal) ─────────────────────────────────────────
model GuestComment {
  id         String       @id @default(cuid())
  shareId    String
  projectId  String
  guestName  String?
  guestEmail String?
  message    String
  createdAt  DateTime     @default(now())
  share      ProjectShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
}

// ─── Projekt-Favoriten ────────────────────────────────────────────────────────
model ProjectFavorite {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

// ─── Sprint-Retrospektive ─────────────────────────────────────────────────────
model Retrospective {
  id        String      @id @default(cuid())
  sprintId  String      @unique
  createdAt DateTime    @default(now())
  items     RetroItem[]
}

model RetroItem {
  id        String        @id @default(cuid())
  retroId   String
  type      String // "gut" | "schlecht" | "verbesserung"
  text      String
  votes     Int           @default(0)
  retro     Retrospective @relation(fields: [retroId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
}

// ─── Pomodoro-Sessions ────────────────────────────────────────────────────────
model PomodoroSession {
  id          String   @id @default(cuid())
  userId      String
  taskId      String?
  duration    Int // Dauer in Minuten (z.B. 25)
  type        String   @default("work") // "work" | "short_break" | "long_break"
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
}

// ─── Report-Scheduler ─────────────────────────────────────────────────────────
model ProjectReportSchedule {
  id        String    @id @default(cuid())
  projectId String
  emails    String[]
  interval  String    @default("weekly") // "weekly" | "monthly"
  lastSent  DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─── Kunden / CRM (Sprint GV) ────────────────────────────────────────────────
model Client {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects        Project[]
  invoices        Invoice[]
  quotes          Quote[]
  InvoiceTemplate InvoiceTemplate[]
}

// ─── Projekt-Kosten (Sprint GS) ───────────────────────────────────────────────
model ProjectCost {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category    String   @default("Sonstiges") // "Material" | "Personal" | "Fahrtkosten" | "Sonstiges"
  amount      Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Angebote / Quotes (Sprint GU) ───────────────────────────────────────────
model Quote {
  id          String   @id @default(cuid())
  number      String   @unique
  projectId   String?
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientName  String
  clientEmail String?
  title       String
  items       Json
  validUntil  DateTime
  status      String   @default("draft")
  note        String?
  pdfUrl      String?
  amount      Float    @default(0)
  invoiceId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Gespeicherte Ansichten ───────────────────────────────────────────────────
model SavedView {
  id        String   @id @default(cuid())
  userId    String
  name      String
  filterRaw String
  icon      String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Auto-Loop (Ralph Loop) ───────────────────────────────────────────────────
model LoopTask {
  id          String    @id @default(cuid())
  title       String
  description String?
  repo        String // ka-forstmanager | ka-app | mission-control | wordpress | research
  priority    String    @default("medium") // high | medium | low
  status      String    @default("todo") // todo | in_progress | done | failed
  result      String?
  errorMsg    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startedAt   DateTime?
  completedAt DateTime?
}

model LoopSettings {
  id               String   @id @default("singleton")
  enabled          Boolean  @default(false)
  scheduleExpr     String   @default("0,30 1-4 * * *")
  timezone         String   @default("Europe/Berlin")
  maxTasksPerNight Int      @default(8)
  model            String   @default("anthropic/claude-opus-4-5")
  updatedAt        DateTime @updatedAt
}

model LoopLog {
  id        String   @id @default(cuid())
  taskId    String?
  message   String
  level     String   @default("info") // info | success | error | warning
  createdAt DateTime @default(now())
}

// ─── Backup Jobs (AF011) ──────────────────────────────────────────────────────
model BackupJob {
  id          String    @id @default(cuid())
  tenantId    String // z.B. "mission-control", "forstmanager", "secondbrain"
  tenantName  String // Anzeigename z.B. "Mission Control DB"
  backupType  String // "neon" | "mysql" | "wp-files"
  status      String    @default("pending") // "pending" | "running" | "success" | "failed" | "skipped"
  startedAt   DateTime?
  completedAt DateTime?
  sizeBytes   BigInt?
  duration    Int? // Sekunden
  error       String?
  backupUrl   String? // Falls extern gespeichert (z.B. S3, Nextcloud)
  metadata    Json? // Zusätzliche Infos (Tabellen-Count, etc.)
  createdAt   DateTime  @default(now())
}

model BackupConfig {
  id               String    @id @default(cuid())
  tenantId         String    @unique
  tenantName       String
  backupType       String // "neon" | "mysql" | "wp-files"
  connectionInfo   String? // Verschlüsselte Connection-Infos (Host, etc. - keine Passwörter im Klartext!)
  enabled          Boolean   @default(true)
  schedule         String    @default("daily") // "daily" | "weekly" | "hourly"
  retentionDays    Int       @default(30)
  lastBackupAt     DateTime?
  lastBackupStatus String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─── Uptime Monitoring (AF012) ────────────────────────────────────────────────
model UptimeCheck {
  id           String   @id @default(cuid())
  tenantId     String // z.B. "mission-control", "forstmanager", "ka-website"
  tenantName   String
  url          String
  status       String // "up" | "down" | "timeout" | "error"
  statusCode   Int?
  responseTime Int? // Millisekunden
  error        String?
  checkedAt    DateTime @default(now())
}

model MonitoringConfig {
  id               String    @id @default(cuid())
  tenantId         String    @unique
  tenantName       String
  url              String
  enabled          Boolean   @default(true)
  checkInterval    Int       @default(5) // Minuten
  timeout          Int       @default(10) // Sekunden
  alertOnDown      Boolean   @default(true)
  consecutiveFails Int       @default(0) // Zähler für aufeinanderfolgende Fehler
  lastStatus       String? // "up" | "down"
  lastCheckedAt    DateTime?
  lastAlertAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─── Sales Pipeline (AF022) ───────────────────────────────────────────────────
model Deal {
  id             String    @id @default(cuid())
  title          String
  company        String
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  value          Float     @default(0) // Potentieller Deal-Wert in €
  stage          String    @default("prospect") // prospect | qualified | demo | proposal | closed-won | closed-lost
  probability    Int       @default(10) // 0-100 Abschluss-Wahrscheinlichkeit
  source         String? // "Website" | "Empfehlung" | "Kaltakquise" | "Messe" | "LinkedIn"
  notes          String?
  industry       String? // Branche z.B. "Forstbetrieb", "Landschaftsbau"
  employees      Int? // Anzahl Mitarbeiter (für Sizing)
  nextAction     String? // Nächster Schritt
  nextActionDate DateTime?
  lostReason     String? // Wenn closed-lost: warum?
  wonDate        DateTime? // Wenn closed-won: wann?
  lostDate       DateTime? // Wenn closed-lost: wann?
  ownerId        String? // Sales-Verantwortlicher
  ownerName      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model DealActivity {
  id         String   @id @default(cuid())
  dealId     String
  type       String // "note" | "call" | "email" | "meeting" | "stage_change"
  content    String
  authorId   String?
  authorName String?
  metadata   String? // JSON für zusätzliche Infos (z.B. alte/neue Stage)
  createdAt  DateTime @default(now())
}

// ─── Integrations (Q024: Slack, Discord, etc.) ────────────────────────────────
model IntegrationConfig {
  id           String    @id @default(cuid())
  type         String    @unique // "slack" | "discord" | "telegram" | "email"
  name         String
  webhookUrl   String?   // Webhook URL für Slack/Discord
  botToken     String?   // Optional: Bot Token für erweiterte Features
  channelId    String?   // Channel/Chat ID
  events       String?   // JSON array: ["task.created", "task.completed", "comment.added"]
  enabled      Boolean   @default(false)
  status       String    @default("inactive") // "active" | "inactive" | "error"
  lastTestedAt DateTime?
  lastError    String?
  metadata     String?   // JSON für zusätzliche Konfiguration
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── KI Token-Tracking ────────────────────────────────────────────────────────
model AiUsage {
  id           String   @id @default(cuid())
  source       String // "api" | "max"
  feature      String // "sprint-tasks" | "project-estimate" | "task-description" | "project-summary" | "foerderberater" | "amadeus-sprint" | "other"
  model        String // "claude-3-5-haiku-20241022" | "claude-sonnet-4-6" | "claude-opus-4-5"
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  costUsd      Float    @default(0) // exakt bei api, geschätzt bei max
  projectId    String? // optional: welches Projekt
  taskId       String? // optional: welcher Task
  sprintId     String? // optional: welcher Sprint
  metadata     String? // JSON string für zusätzliche Infos
  createdAt    DateTime @default(now())
}

// ─── AI Budget Config (AF056) ─────────────────────────────────────────────────
model AiBudgetConfig {
  id                   String   @id @default("singleton")
  dailyBudgetUsd       Float    @default(5.0)   // Tagesbudget in USD
  monthlyBudgetUsd     Float    @default(100.0) // Monatsbudget in USD
  alertThreshold       Float    @default(0.8)   // Alert bei 80% des Budgets
  alertEnabled         Boolean  @default(true)
  alertTelegram        Boolean  @default(true)
  alertEmail           Boolean  @default(false)
  alertEmails          String[] @default([])    // E-Mail-Adressen für Alerts
  lastDailyAlertAt     DateTime?
  lastMonthlyAlertAt   DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ─── Agent ROI Tracking (AF057) ───────────────────────────────────────────────
model AgentTaskRoi {
  id                    String   @id @default(cuid())
  taskTitle             String
  taskDescription       String?
  category              String   @default("other") // "code" | "research" | "content" | "qa" | "devops" | "design" | "other"
  agentName             String   @default("Amadeus") // Agent der den Task ausgeführt hat
  estimatedManualHours  Float    // Geschätzte manuelle Zeit in Stunden
  actualAgentMinutes    Float    // Tatsächliche Agenten-Zeit in Minuten
  costUsd               Float    @default(0) // API-Kosten
  savedHours            Float?   // Berechnet: estimatedManualHours - (actualAgentMinutes/60)
  hourlyRateSaved       Float    @default(75) // Angenommener Stundensatz €/h für Einsparungsberechnung
  projectId             String?
  projectName           String?
  completedAt           DateTime @default(now())
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ─── OKR System (Q028) ────────────────────────────────────────────────────────
model Objective {
  id          String    @id @default(cuid())
  title       String
  description String?
  period      String    // "Q1 2026", "Q2 2026", etc.
  deadline    DateTime?
  status      String    @default("on-track") // "on-track" | "at-risk" | "off-track" | "completed"
  progress    Int       @default(0) // 0-100, berechnet aus Key Results
  projectId   String?   // Optional: Verknüpfung mit Projekt
  ownerId     String?
  ownerName   String?
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  keyResults  KeyResult[]
}

model KeyResult {
  id          String    @id @default(cuid())
  objectiveId String
  objective   Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  title       String
  metric      String?   // Was wird gemessen? z.B. "MRR", "Anzahl Kunden"
  current     Float     @default(0)
  target      Float     @default(100)
  unit        String?   // "%", "€", "Kunden", etc.
  progress    Int       @default(0) // 0-100
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Upselling Trigger System (AF068) ─────────────────────────────────────────
model UpsellConfig {
  id                    String   @id @default("singleton")
  enabled               Boolean  @default(true)
  // Trigger Schwellwerte
  userThreshold         Int      @default(5)      // Ab X Nutzer → Pro Upgrade
  taskMonthlyThreshold  Int      @default(100)    // Ab X Tasks/Monat → Pro Upgrade
  apiCostThreshold      Float    @default(20.0)   // Ab X USD/Monat → Enterprise
  storageThreshold      Int      @default(500)    // Ab X MB Dokumente → Storage Addon
  // Benachrichtigungen
  alertTelegram         Boolean  @default(true)
  alertEmail            Boolean  @default(false)
  alertEmails           String[] @default([])
  // Cooldown (verhindert Spam)
  cooldownDays          Int      @default(30)     // Min. Tage zwischen Alerts pro Tenant
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model UpsellTrigger {
  id            String    @id @default(cuid())
  tenantId      String    // Tenant/Projekt/Kunde Identifier
  tenantName    String
  triggerType   String    // "users" | "tasks" | "api_cost" | "storage" | "feature_request"
  triggerValue  Float     // Aktueller Wert der den Trigger ausgelöst hat
  threshold     Float     // Schwellwert der überschritten wurde
  suggestedPlan String    // "pro" | "enterprise" | "storage_addon" | "custom"
  message       String    // Upselling-Nachricht für Sales
  status        String    @default("new") // "new" | "contacted" | "converted" | "dismissed"
  priority      String    @default("medium") // "low" | "medium" | "high"
  metadata      String?   // JSON für zusätzliche Infos
  contactedAt   DateTime?
  convertedAt   DateTime?
  dismissedAt   DateTime?
  notes         String?   // Sales-Notizen
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── Meeting Notes (Q032) ─────────────────────────────────────────────────────
model Meeting {
  id            String    @id @default(cuid())
  title         String
  date          DateTime
  duration      Int?      // Minuten
  location      String?   // "Video-Call" | "Büro" | "Telefon" | "Vor Ort"
  // Teilnehmer (JSON array: [{name: "Tomek", email: "..."}, ...])
  participants  String?
  // Inhalte
  agenda        String?   // Markdown
  notes         String?   // Markdown — Protokoll
  decisions     String?   // Markdown — Beschlüsse
  // Verknüpfungen
  projectId     String?
  projectName   String?
  organizerId   String?   // AuthUser ID
  organizerName String?
  // Status
  status        String    @default("scheduled") // "scheduled" | "completed" | "cancelled"
  isArchived    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // Relations
  actionItems   MeetingActionItem[]
}

model MeetingActionItem {
  id          String    @id @default(cuid())
  meetingId   String
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  title       String
  assigneeId  String?   // AuthUser oder User ID
  assigneeName String?
  dueDate     DateTime?
  status      String    @default("open") // "open" | "in_progress" | "done"
  taskId      String?   // Optional: Verknüpfung mit Task (wenn aus Action Item ein Task erstellt wurde)
  priority    String    @default("medium") // "low" | "medium" | "high"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Decisions Log (Q050) ─────────────────────────────────────────────────────
model Decision {
  id             String    @id @default(cuid())
  title          String
  decisionDate   DateTime  @default(now())
  context        String?   // Warum wurde diese Entscheidung getroffen? (Markdown)
  decision       String    // Was wurde entschieden? (Markdown)
  alternatives   String?   // Welche Alternativen wurden betrachtet? (Markdown)
  impact         String?   // Erwartete Auswirkung (Markdown)
  category       String    @default("Tech") // "Tech" | "Business" | "Product" | "Prozess" | "Team" | "Sonstiges"
  status         String    @default("active") // "active" | "superseded" | "reversed"
  ownerId        String?   // AuthUser ID des Verantwortlichen
  ownerName      String?
  projectId      String?   // Optional: Verknüpfung mit Projekt
  projectName    String?
  tags           String?   // Komma-separierte Tags für Filter
  supersededBy   String?   // ID der neuen Entscheidung wenn superseded
  reversedReason String?   // Grund für Aufhebung wenn reversed
  isArchived     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Risk Register (Q037) ─────────────────────────────────────────────────────
model Risk {
  id             String    @id @default(cuid())
  title          String
  description    String?
  category       String    @default("Tech") // "Tech" | "Business" | "Ressourcen" | "Legal" | "External"
  probability    Int       @default(3) // 1-5 (1=sehr gering, 5=sehr hoch)
  impact         Int       @default(3) // 1-5 (1=minimal, 5=kritisch)
  riskScore      Int?      // Berechnet: probability × impact (1-25)
  status         String    @default("identified") // "identified" | "mitigated" | "accepted" | "closed"
  mitigations    String?   // Gegenmaßnahmen (Markdown)
  contingency    String?   // Notfallplan falls Risiko eintritt
  ownerId        String?
  ownerName      String?
  projectId      String?   // Optional: Verknüpfung mit Projekt
  dueDate        DateTime? // Deadline für Gegenmaßnahmen
  lastReviewedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Customer Onboarding Tracking (AF083: Cleo-Agent) ─────────────────────────
model CustomerOnboarding {
  id              String    @id @default(cuid())
  tenantId        String    @unique // z.B. "koch-aufforstung", "kunde-2"
  tenantName      String    // Anzeigename
  projectId       String?   // Optional: Verknüpfung mit MC-Projekt
  // Status
  status          String    @default("in_progress") // "in_progress" | "completed" | "paused" | "cancelled"
  week            Int       @default(1) // Aktuelle Onboarding-Woche (1-4)
  startDate       DateTime  @default(now())
  targetGoLive    DateTime? // Geplantes Go-Live-Datum
  actualGoLive    DateTime? // Tatsächliches Go-Live
  // Woche 1: Kickoff
  w1_kickoff         Boolean @default(false)
  w1_requirements    Boolean @default(false)
  w1_configPlan      Boolean @default(false)
  // Woche 2: Setup
  w2_domain          Boolean @default(false)
  w2_database        Boolean @default(false)
  w2_appSetup        Boolean @default(false)
  w2_dataImport      Boolean @default(false)
  // Woche 3: Training
  w3_adminTraining   Boolean @default(false)
  w3_workerTraining  Boolean @default(false)
  w3_testRun         Boolean @default(false)
  // Woche 4: Go-Live
  w4_finalCheck      Boolean @default(false)
  w4_goLive          Boolean @default(false)
  w4_supportHandover Boolean @default(false)
  // Zusätzliche Checkpoints
  avvSigned          Boolean @default(false) // Auftragsverarbeitungsvertrag
  contractSigned     Boolean @default(false) // SaaS-Vertrag
  firstPayment       Boolean @default(false) // Erste Zahlung eingegangen
  // Meta
  contactName        String?
  contactEmail       String?
  notes              String? // Freitext-Notizen
  lastReminderSentAt DateTime?
  reminderCount      Int     @default(0)
  ownerId            String? // Zuständiger Sales/PM
  ownerName          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── Onboarding Check Config (Cleo-Agent Settings) ────────────────────────────
model OnboardingCheckConfig {
  id                   String   @id @default("singleton")
  enabled              Boolean  @default(true)
  // Benachrichtigungen
  alertTelegram        Boolean  @default(true)
  alertSlack           Boolean  @default(false)
  // Schwellwerte
  staleDaysThreshold   Int      @default(7)  // Tage ohne Fortschritt → Alert
  reminderCooldownDays Int      @default(3)  // Min. Tage zwischen Erinnerungen
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ============================================================
// ACCESS LOGGING FÜR PERSONENBEZOGENE DATEN (Sprint DA-29)
// DSGVO-konforme Protokollierung aller Zugriffe auf PD
// Retention: 90 Tage (automatische Löschung via Cron)
// ============================================================

model PdAccessLog {
  id         String   @id @default(cuid())
  userId     String?  // User-ID des Zugreifenden (null bei unauthentifiziert)
  userName   String?  // Name des Users (für Archiv, falls User gelöscht)
  resource   String   // Betroffene Ressource: USER_PROFILE, AUTH_USER, INVOICE, EXPENSE
  resourceId String?  // ID des spezifischen Datensatzes (optional)
  action     String   // READ, WRITE, DELETE, EXPORT, BULK_READ
  ip         String?  // IP-Adresse des Zugreifenden
  userAgent  String?  // Browser/Client
  endpoint   String?  // API-Endpoint z.B. "/api/users/123"
  method     String?  // HTTP-Methode: GET, POST, PUT, DELETE
  statusCode Int?     // HTTP-Statuscode der Antwort
  metadata   Json?    // Zusätzliche Daten (z.B. Filter-Parameter bei Bulk-Read)
  createdAt  DateTime @default(now())
  // Retention: Einträge >90 Tage werden via Cron gelöscht
  // Kein updatedAt - Einträge sind immutable

  @@index([userId])
  @@index([resource])
  @@index([createdAt])
  @@index([ip])
}

// ============================================================
// TENANT MANAGEMENT (Multi-Tenant Feldhub Platform)
// ============================================================

model Tenant {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  industry     String?
  status       String    @default("active")
  contactName  String?
  contactEmail String?
  contactPhone String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  systems      TenantSystem[]
  contracts    TenantContract[]
}

model TenantSystem {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  type      String
  url       String?
  status    String   @default("live")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenantContract {
  id           String    @id @default(cuid())
  tenantId     String
  type         String    @default("saas")
  status       String    @default("active")
  startDate    DateTime
  endDate      DateTime?
  monthlyRate  Float     @default(0)
  setupFee     Float     @default(0)
  billingCycle String    @default("monthly")
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── Worker Results (System Health) ──────────────────────────────────────────
model WorkerResult {
  id        String   @id @default(cuid())
  taskName  String
  runTs     DateTime @default(now())
  status    String   @default("ok") // "ok" | "warning" | "error"
  summary   String?
  domain    String?  // "operations" | "security" | "compliance" etc.
  severity  String   @default("info") // "info" | "warning" | "error" | "critical"
  findings  Json?    // Array of finding objects
  metrics   Json?    // Key-value metrics
  createdAt DateTime @default(now())

  @@index([taskName, runTs])
}
