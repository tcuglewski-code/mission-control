generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  role           String   @default("human")
  avatar         String?
  description    String?
  tools          String?  // JSON array of tool names
  skills         String?  // JSON array of skill names
  weeklyCapacity Int      @default(40) // Wochenkapazität in Stunden
  createdAt      DateTime @default(now())
  tasks          Task[]
  projects       ProjectMember[]
  logs           ActivityLog[]
  tickets        Ticket[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  longDescription String? // Living document — grows with the project
  status      String   @default("active")
  progress    Int      @default(0)
  priority    String   @default("medium")
  color       String   @default("#3b82f6")
  // Meta / Links
  githubRepo    String?  // e.g. "tcuglewski-code/ka-app"
  liveUrl       String?  // Production URL
  vercelUrl     String?  // Vercel deployment URL
  expoProjectId String?  // Expo / EAS project ID
  stack         String?  // Tech stack description
  budget          Float?   // Geplantes Budget in €
  budgetUsed      Float?   @default(0) // Verbrauchtes Budget
  archived    Boolean   @default(false)
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks      Task[]
  sprints    Sprint[]
  milestones Milestone[]
  members    ProjectMember[]
  docs       Document[]
  fileDocs   FileDoc[]
  logs       ActivityLog[]
  databases  Database[]
  tickets    Ticket[]
  webhooks   Webhook[]
  invoices   Invoice[]
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      String  @default("member")
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([projectId, userId])
}

model Task {
  id               String    @id @default(cuid())
  title            String
  description      String?
  status           String    @default("todo")
  priority         String    @default("medium")
  labels           String?
  dueDate          DateTime?
  startDate        DateTime?
  agentPrompt      String?
  timeSpentSeconds Int       @default(0)
  storyPoints      Int?
  sourceEmailId    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  projectId   String?
  assigneeId  String?
  sprintId    String?
  milestoneId String?
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee  User?      @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  sprint    Sprint?    @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  milestone Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  sourceEmail InboxEmail? @relation(fields: [sourceEmailId], references: [id], onDelete: SetNull)
  comments    TaskComment[]
  events      Event[]
  timeEntries TimeEntry[]
  taskLabels  TaskLabel[]
}

// ─── E-Mail Posteingang ───────────────────────────────────────────────────────
model InboxEmail {
  id          String    @id @default(cuid())
  from        String
  subject     String
  body        String?
  preview     String?   // Vorschautext (max. 200 Zeichen)
  receivedAt  DateTime  @default(now())
  read        Boolean   @default(false)
  taskCreated Boolean   @default(false)
  tasks       Task[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Label {
  id         String      @id @default(cuid())
  name       String      @unique
  color      String      @default("#6b7280")
  createdAt  DateTime    @default(now())
  taskLabels TaskLabel[]
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label @relation(fields: [labelId], references: [id], onDelete: Cascade)
  @@id([taskId, labelId])
}

model TimeEntry {
  id          String    @id @default(cuid())
  taskId      String
  userId      String?
  description String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int?      // Minuten
  billable    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Sprint {
  id              String    @id @default(cuid())
  name            String
  description     String?
  status          String    @default("planning")
  startDate       DateTime?
  endDate         DateTime?
  goal            String?
  projectId       String?
  storyPoints     Int?
  completedPoints Int?
  memberIds       String?   // JSON array of user IDs assigned to this sprint
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tasks           Task[]
}

model TaskComment {
  id          String   @id @default(cuid())
  content     String
  taskId      String
  authorId    String?
  authorName  String   @default("Amadeus")
  authorEmail String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Document {
  id          String   @id @default(cuid())
  title       String
  content     String
  type        String   @default("doc")
  tags        String?
  projectId   String?
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model MemoryEntry {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String   @default("general")
  type        String   @default("journal")  // "journal" | "longterm"
  tags        String?
  source      String?
  projectId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tool {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("api")
  status      String   @default("active")
  config      String?
  projectIds  String?
  createdAt   DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("task")
  color       String   @default("#3b82f6")
  startTime   DateTime
  endTime     DateTime?
  recurring   String?
  taskId      String?
  createdAt   DateTime @default(now())
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  entityName String
  userId     String?
  userEmail  String?
  projectId  String?
  metadata   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model CronJob {
  id            String    @id @default(cuid())
  name          String
  description   String?
  schedule      String
  scheduleHuman String?
  type          String    @default("system")
  status        String    @default("active")
  lastRun       DateTime?
  nextRun       DateTime?
  payload       String?
  projectId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Database {
  id          String    @id @default(cuid())
  name        String
  type        String    // "postgresql", "mysql", "mongodb", "watermelondb", "neon"
  host        String?
  port        Int?
  status      String    @default("unknown") // "connected", "disconnected", "unknown"
  sizeBytes   BigInt?
  lastBackup  DateTime?
  lastChecked DateTime?
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Ticket {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("open")    // "open", "in_progress", "resolved", "closed"
  priority    String   @default("medium")  // "low", "medium", "high", "critical"
  category    String?                      // "bug", "feature", "support", "question"
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  assigneeId  String?
  assignee    User?    @relation(fields: [assigneeId], references: [id])
  taskId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Webhook {
  id            String    @id @default(cuid())
  name          String
  url           String
  secret        String?
  events        String[]
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  active        Boolean   @default(true)
  lastTriggered DateTime?
  lastStatus    Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model WebhookLog {
  id        String   @id @default(cuid())
  webhookId String
  event     String
  payload   String
  status    Int
  response  String?
  duration  Int
  createdAt DateTime @default(now())
}

model AuthUser {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String?
  passwordHash  String
  role          String   @default("user") // "admin" | "user"
  mcRole        String   @default("entwickler") // "admin" | "projektmanager" | "entwickler" | "beobachter"
  active        Boolean  @default(true)
  lastLoginAt   DateTime?
  projectAccess String[] // Array von Project-IDs (leer = kein Zugang für user)
  permissions   String[] // Granulare Rechte z.B. ["projects.view", "tasks.view"]
  notifEmailDigest Boolean @default(true)
  notifPush     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  notifications Notification[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "task_update" | "deadline" | "cron_result" | "mention"
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invitation {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  email       String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  keyPrefix  String
  userId     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
}

// ─── Agent Registry (erweitert) ───────────────────────────────────────────────
model AgentRegistry {
  id              String    @id @default(cuid())
  name            String    @unique
  beschreibung    String?
  capabilities    String[]  // Liste der Fähigkeiten z.B. ["code", "search", "email"]
  status          String    @default("unknown") // "online" | "offline" | "unknown"
  letzteAktivitaet DateTime?
  version         String?
  endpoint        String?   // API-Endpoint des Agenten (optional)
  metadata        String?   // JSON für zusätzliche Felder
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── Daily Digest ─────────────────────────────────────────────────────────────
model DailyDigest {
  id        String   @id @default(cuid())
  datum     DateTime @unique
  inhalt    String   // Markdown-Zusammenfassung
  tasksDone Int      @default(0)
  tasksOffen Int     @default(0)
  tasksNeu  Int      @default(0)
  createdAt DateTime @default(now())
}

// ─── Task Dependencies ────────────────────────────────────────────────────────
model TaskDependency {
  id          String @id @default(cuid())
  taskId      String
  dependsOnId String
  @@unique([taskId, dependsOnId])
}

// ─── Projekt-Vorlagen ─────────────────────────────────────────────────────────
model ProjectTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?  // "aufforstung", "pflege", "saatgut", etc.
  tasks       Json     // Array von Task-Definitionen
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Webhook Einstellungen (ausgehend) ────────────────────────────────────────
model WebhookEinstellung {
  id        String   @id @default(cuid())
  name      String
  url       String
  events    String[] // "task.created" | "task.updated" | "task.completed" | "task.deleted"
  aktiv     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Ankündigungen ────────────────────────────────────────────────────────────
model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  priority  String   @default("normal") // "normal", "wichtig", "dringend"
  authorId  String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Datei-Dokumente (Link-Upload) ────────────────────────────────────────────
model FileDoc {
  id            String   @id @default(cuid())
  name          String
  description   String?
  url           String                       // Externe URL oder interner Download-Link
  fileType      String   @default("link")    // "pdf" | "word" | "excel" | "image" | "link" | "other"
  size          Int?                         // Dateigröße in Bytes (null bei Links)
  uploader      String   @default("System")
  uploaderEmail String?
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Rechnungen / Invoices ────────────────────────────────────────────────────
model Invoice {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number      String    // Rechnungsnummer z.B. RE-2024-001
  description String?
  amount      Float     // Betrag in €
  status      String    @default("OPEN") // OPEN | PAID | OVERDUE | CANCELLED
  dueDate     DateTime
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Meilensteine ─────────────────────────────────────────────────────────────
model Milestone {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("planned") // "planned", "active", "completed", "cancelled"
  progress    Int       @default(0) // 0-100, kann automatisch aus Tasks berechnet werden
  color       String    @default("#8b5cf6")
  dueDate     DateTime?
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
